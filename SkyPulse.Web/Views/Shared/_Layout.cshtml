<!DOCTYPE html>
<html lang="en" class="h-100">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SkyPulse Enterprise // Command Center</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column h-100">
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-custom mb-3 py-3">
            <div class="container-fluid px-4">
                <a class="navbar-brand navbar-brand-ops" asp-area="" asp-controller="Home" asp-action="Index">SKY<span>PULSE</span></a>
                <button class="navbar-toggler navbar-dark" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 ms-4">
                        <li class="nav-item me-3">
                            <a class="nav-link nav-link-ops px-2" asp-controller="Home" asp-action="Dashboard">LIVE PLATFORM</a>
                        </li>
                        <li class="nav-item me-3">
                            <a class="nav-link nav-link-ops px-2" asp-controller="Home" asp-action="Analytics">TRACKING DATA / ANALYTICS SUITE</a>
                        </li>
                    </ul>
                    <span class="navbar-text tech-mono text-uppercase small px-3 py-1 rounded border border-secondary border-opacity-25 bg-dark text-white-50">
                        Secured Terminal // Node_01
                    </span>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid px-4 flex-shrink-0">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer mt-auto py-4 bg-transparent">
        <div class="container-fluid px-4 d-flex justify-content-between align-items-center">
            <span>&copy; 2026 - SkyPulse Enterprise Deep-Space Platform</span>
            <span class="tech-mono small text-success">● SYSTEM STATUS: OPTIMAL</span>
        </div>
    </footer>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>